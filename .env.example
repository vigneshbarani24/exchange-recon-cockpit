# UiPath External Application (Admin -> External Applications -> Non Confidential)
# Redirect URI registered there must be exactly http://localhost:5173
VITE_UIPATH_CLIENT_ID=your-oauth-client-id
VITE_UIPATH_ORG_NAME=your-org
VITE_UIPATH_TENANT_NAME=your-tenant
VITE_UIPATH_BASE_URL=https://cloud.uipath.com
VITE_UIPATH_REDIRECT_URI=http://localhost:5173

# Scopes must match what the External Application grants.
VITE_UIPATH_SCOPE=PIMS DataFabric.Schema.Read DataFabric.Data.Read DataFabric.Data.Write OR.Tasks OR.Folders.Read

# Folder containing the Maestro process + Action Center tasks.
# Maestro uses folderKey (string); Orchestrator tasks use folderId (number).
VITE_UIPATH_FOLDER_KEY=your-folder-key
VITE_UIPATH_FOLDER_ID=0

# Match the Maestro process by display name (case-insensitive contains).
VITE_EXCHANGE_PROCESS_NAME=Exchange

# Live queue poll interval (ms).
VITE_POLL_MS=8000

# DEMO-ONLY (vb/demo/safe-mode branch). When 1, live tenant calls that fail or
# return empty fall back to cached data so a recording never dies mid-take.
# Leave unset / 0 on main and against the real tenant.
VITE_DEMO_FALLBACK=0
