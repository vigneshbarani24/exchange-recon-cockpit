<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="UiPath Maestro (https://uipath.com)" exporterVersion="development">
  <bpmn:error id="Error_AgentFailed" name="Agent failed" errorCode="AGENT_FAILED" />
  <bpmn:process id="ExchangeSettlementReconciliation" name="PO Reconciliation (Procure-to-Pay)">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_PurchaseOrder" name="purchaseOrder" type="string" elementId="Event_start" />
        <uipath:inputOutput id="Var_SupplierDocument" name="supplierDocument" type="string" elementId="Event_start" />
        <uipath:inputOutput id="Var_MatchedLines" name="matchedLines" type="string" />
        <uipath:inputOutput id="Var_WithinTolerance" name="withinTolerance" type="boolean" />
        <uipath:inputOutput id="Var_Variances" name="variances" type="string" />
        <uipath:inputOutput id="Var_Decision" name="decision" type="string" />
        <uipath:inputOutput id="Var_ReviewerNote" name="reviewerNote" type="string" />
        <uipath:inputOutput id="Var_PreparedUpdate" name="preparedUpdate" type="string" />
        <uipath:output id="Var_Outcome" name="outcome" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Event_start" name="Supplier invoice received">
      <bpmn:extensionElements>
        <uipath:entryPointId value="ec7053b7-6bb1-4617-a077-dc837ddc5e99" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_start_match</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_MatchAgent" name="Matching agent: align supplier lines to PO">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="ReleaseKey" type="string" value="AGENT_PROCESS_KEY_GUID" />
            <uipath:input name="FolderKey" type="string" value="FOLDER_KEY_GUID" />
            <uipath:input name="FolderPath" type="string" value="Shared/ExchangeRecon" />
            <uipath:input name="Name" type="string" value="Matching Agent" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"purchase_order":"=vars.Var_PurchaseOrder","supplier_document":"=vars.Var_SupplierDocument"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_MatchedLines" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_start_match</bpmn:incoming>
      <bpmn:outgoing>Flow_match_tolerance</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Boundary_MatchError" attachedToRef="Task_MatchAgent">
      <bpmn:outgoing>Flow_match_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_MatchError" errorRef="Error_AgentFailed" />
    </bpmn:boundaryEvent>
    <bpmn:scriptTask id="Task_Tolerance" name="Tolerance check" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"matchedLines":"=vars.Var_MatchedLines"}]]></uipath:input>
          <uipath:output name="withinTolerance" type="boolean" var="Var_WithinTolerance" source="=result.response.withinTolerance" />
          <uipath:output name="variances" type="string" var="Var_Variances" source="=result.response.variances" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_match_tolerance</bpmn:incoming>
      <bpmn:outgoing>Flow_tolerance_gateway</bpmn:outgoing>
      <bpmn:script><![CDATA[
var priceTolerancePct = 2.0;
var qtyTolerance = 1.0;
var lines = [];
try { lines = JSON.parse(matchedLines).lines || []; } catch (e) { lines = []; }
var offending = [];
for (var i = 0; i < lines.length; i++) {
  var line = lines[i];
  var poPrice = Number(line.poPrice);
  var invoicePrice = Number(line.invoicePrice);
  var poQty = Number(line.poQty);
  var invoiceQty = Number(line.invoiceQty);
  var priceDelta = poPrice === 0 ? 0 : Math.abs((invoicePrice - poPrice) / poPrice) * 100;
  var qtyDelta = Math.abs(invoiceQty - poQty);
  if (priceDelta > priceTolerancePct || qtyDelta > qtyTolerance) {
    offending.push("Line " + (line.lineNo || (i + 1)) + ": price " + priceDelta.toFixed(1) + "% / qty " + qtyDelta.toFixed(1));
  }
}
var withinTolerance = offending.length === 0;
return { response: { withinTolerance: withinTolerance, variances: offending.length ? offending.join("; ") : "none" } };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_Tolerance" name="Within tolerance?" default="Flow_variance">
      <bpmn:incoming>Flow_tolerance_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_within_tolerance</bpmn:outgoing>
      <bpmn:outgoing>Flow_variance</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Task_AutoApprove" name="Post / auto-approve" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"variances":"=vars.Var_Variances"}]]></uipath:input>
          <uipath:output name="outcome" type="string" var="Var_Outcome" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_within_tolerance</bpmn:incoming>
      <bpmn:outgoing>Flow_autoapprove_end</bpmn:outgoing>
      <bpmn:script><![CDATA[
return { response: "Within tolerance. Invoice auto-approved and PO matched for posting." };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_AutoApproved" name="Auto-approved">
      <bpmn:incoming>Flow_autoapprove_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_VarianceAgent" name="Variance agent: classify and propose correction">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="ReleaseKey" type="string" value="AGENT_PROCESS_KEY_GUID" />
            <uipath:input name="FolderKey" type="string" value="FOLDER_KEY_GUID" />
            <uipath:input name="FolderPath" type="string" value="Shared/ExchangeRecon" />
            <uipath:input name="Name" type="string" value="Variance Agent" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"purchase_order":"=vars.Var_PurchaseOrder","matched_lines":"=vars.Var_MatchedLines","variances":"=vars.Var_Variances"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_Variances" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_variance</bpmn:incoming>
      <bpmn:outgoing>Flow_agent_gate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Boundary_AgentError" attachedToRef="Task_VarianceAgent">
      <bpmn:outgoing>Flow_agent_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_AgentError" errorRef="Error_AgentFailed" />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_HumanGate" name="Human gate: approve or escalate">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v1" />
          <uipath:context />
          <uipath:input name="HitlTaskArguments" type="json" target="bodyField"><![CDATA[{"purchaseOrder":"=vars.Var_PurchaseOrder","variances":"=vars.Var_Variances","preparedUpdate":"=vars.Var_PreparedUpdate"}]]></uipath:input>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_Decision" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_agent_gate</bpmn:incoming>
      <bpmn:outgoing>Flow_gate_decision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Boundary_GateTimeout" attachedToRef="Task_HumanGate">
      <bpmn:outgoing>Flow_gate_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_GateTimeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Decision?" default="Flow_escalate">
      <bpmn:incoming>Flow_gate_decision</bpmn:incoming>
      <bpmn:outgoing>Flow_approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_escalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_PostingPrepAgent" name="Posting-prep agent: build PO item update">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="ReleaseKey" type="string" value="AGENT_PROCESS_KEY_GUID" />
            <uipath:input name="FolderKey" type="string" value="FOLDER_KEY_GUID" />
            <uipath:input name="FolderPath" type="string" value="Shared/ExchangeRecon" />
            <uipath:input name="Name" type="string" value="Posting-prep Agent" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"purchase_order":"=vars.Var_PurchaseOrder","variances":"=vars.Var_Variances","reviewer_note":"=vars.Var_ReviewerNote"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_PreparedUpdate" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_approve</bpmn:incoming>
      <bpmn:outgoing>Flow_prep_update</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Boundary_PrepError" attachedToRef="Task_PostingPrepAgent">
      <bpmn:outgoing>Flow_prep_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_PrepError" errorRef="Error_AgentFailed" />
    </bpmn:boundaryEvent>
    <bpmn:scriptTask id="Task_UpdatePO" name="Update PO item in S/4" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"purchaseOrder":"=vars.Var_PurchaseOrder","preparedUpdate":"=vars.Var_PreparedUpdate","reviewerNote":"=vars.Var_ReviewerNote"}]]></uipath:input>
          <uipath:output name="outcome" type="string" var="Var_Outcome" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_prep_update</bpmn:incoming>
      <bpmn:outgoing>Flow_update_end</bpmn:outgoing>
      <bpmn:script><![CDATA[
var note = reviewerNote ? " Reviewer note: " + reviewerNote : "";
return { response: "PO item " + (purchaseOrder || "") + " corrected and written back to S/4." + note };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_Corrected" name="Corrected &amp; closed">
      <bpmn:incoming>Flow_update_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="Task_RouteBuyer" name="Route to buyer" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"purchaseOrder":"=vars.Var_PurchaseOrder","variances":"=vars.Var_Variances"}]]></uipath:input>
          <uipath:output name="outcome" type="string" var="Var_Outcome" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_escalate</bpmn:incoming>
      <bpmn:incoming>Flow_match_error</bpmn:incoming>
      <bpmn:incoming>Flow_agent_error</bpmn:incoming>
      <bpmn:incoming>Flow_prep_error</bpmn:incoming>
      <bpmn:incoming>Flow_gate_timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_routebuyer_end</bpmn:outgoing>
      <bpmn:script><![CDATA[
return { response: "Escalated to the buyer for manual handling." };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="End_Escalated" name="Escalated">
      <bpmn:incoming>Flow_routebuyer_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_match" sourceRef="Event_start" targetRef="Task_MatchAgent" />
    <bpmn:sequenceFlow id="Flow_match_tolerance" sourceRef="Task_MatchAgent" targetRef="Task_Tolerance" />
    <bpmn:sequenceFlow id="Flow_match_error" sourceRef="Boundary_MatchError" targetRef="Task_RouteBuyer" />
    <bpmn:sequenceFlow id="Flow_tolerance_gateway" sourceRef="Task_Tolerance" targetRef="Gateway_Tolerance" />
    <bpmn:sequenceFlow id="Flow_within_tolerance" name="Within tolerance" sourceRef="Gateway_Tolerance" targetRef="Task_AutoApprove">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_WithinTolerance == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_variance" name="Variance" sourceRef="Gateway_Tolerance" targetRef="Task_VarianceAgent" />
    <bpmn:sequenceFlow id="Flow_autoapprove_end" sourceRef="Task_AutoApprove" targetRef="End_AutoApproved" />
    <bpmn:sequenceFlow id="Flow_agent_gate" sourceRef="Task_VarianceAgent" targetRef="Task_HumanGate" />
    <bpmn:sequenceFlow id="Flow_agent_error" sourceRef="Boundary_AgentError" targetRef="Task_RouteBuyer" />
    <bpmn:sequenceFlow id="Flow_gate_decision" sourceRef="Task_HumanGate" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_gate_timeout" sourceRef="Boundary_GateTimeout" targetRef="Task_RouteBuyer" />
    <bpmn:sequenceFlow id="Flow_approve" name="Approve" sourceRef="Gateway_Decision" targetRef="Task_PostingPrepAgent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_Decision == &quot;Approve&quot;</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_escalate" name="Escalate" sourceRef="Gateway_Decision" targetRef="Task_RouteBuyer" />
    <bpmn:sequenceFlow id="Flow_prep_update" sourceRef="Task_PostingPrepAgent" targetRef="Task_UpdatePO" />
    <bpmn:sequenceFlow id="Flow_prep_error" sourceRef="Boundary_PrepError" targetRef="Task_RouteBuyer" />
    <bpmn:sequenceFlow id="Flow_update_end" sourceRef="Task_UpdatePO" targetRef="End_Corrected" />
    <bpmn:sequenceFlow id="Flow_routebuyer_end" sourceRef="Task_RouteBuyer" targetRef="End_Escalated" />
  </bpmn:process>
