# SAP MCP connection for the coded agent. Copy to .env (gitignored) and fill in.
# The agent reaches the BTP-hosted SAP OData MCP server directly.

SAP_MCP_URL=https://<your-mcp-host>/mcp

# Auth — provide ONE method (the agent picks them up in this priority order):
# 1) XSUAA client-credentials (recommended; non-interactive, works for a deployed agent):
SAP_MCP_CLIENT_ID=
SAP_MCP_CLIENT_SECRET=
SAP_MCP_TOKEN_URL=https://<your-subaccount>.authentication.<region>.hana.ondemand.com
# 2) a static bearer token:
SAP_MCP_TOKEN=
# 3) a full Authorization header value (takes precedence over the above):
SAP_MCP_AUTH_HEADER=

# Plus `uipath auth` for the LLM gateway (writes UIPATH_* into .env).
