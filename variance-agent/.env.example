# SAP Cloud VB MCP connection for the coded agent.
# Copy to .env (gitignored) and fill in. The agent reaches the BTP-hosted MCP directly.

SAP_MCP_URL=https://<host>.cfapps.eu10-004.hana.ondemand.com/mcp

# Provide ONE of the following auth methods:
# 1) a bearer token (wrapped as "Bearer <token>"):
SAP_MCP_TOKEN=
# 2) a full Authorization header value (takes precedence over SAP_MCP_TOKEN):
SAP_MCP_AUTH_HEADER=
