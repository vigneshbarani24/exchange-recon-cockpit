{
    "$schema": "https://cloud.uipath.com/draft/2024-12/entry-point",
    "$id": "entry-points.json",
    "entryPoints": [
        {
            "filePath": "agent",
            "uniqueId": "e01536bc-edbb-4e8f-a9c1-2ee064584d77",
            "type": "agent",
            "input": {
                "type": "object",
                "properties": {
                    "purchase_order": {
                        "description": "The S/4 purchase order number to reconcile, e.g. '4500000021'.",
                        "title": "Purchase Order",
                        "type": "string"
                    },
                    "supplier_document": {
                        "description": "The inbound supplier order-confirmation / invoice for this PO (text or JSON): per-line material, quantity, unit price, currency.",
                        "title": "Supplier Document",
                        "type": "string"
                    },
                    "tolerance_pct": {
                        "default": 2.0,
                        "description": "Per-line price/quantity tolerance in percent; within this a line is treated as matched.",
                        "title": "Tolerance Pct",
                        "type": "number"
                    }
                },
                "required": [
                    "purchase_order",
                    "supplier_document"
                ]
            },
            "output": {
                "type": "object",
                "properties": {
                    "purchase_order": {
                        "title": "Purchase Order",
                        "type": "string"
                    },
                    "overall_status": {
                        "description": "within-tolerance | variance-found | error",
                        "title": "Overall Status",
                        "type": "string"
                    },
                    "summary": {
                        "description": "One-line summary of the reconciliation outcome.",
                        "title": "Summary",
                        "type": "string"
                    },
                    "confidence": {
                        "description": "0.0\u20131.0 confidence in the reconciliation; lower it when ambiguous.",
                        "title": "Confidence",
                        "type": "number"
                    },
                    "line_variances": {
                        "items": {
                            "properties": {
                                "po_item": {
                                    "description": "PO item number, e.g. '10'.",
                                    "title": "Po Item",
                                    "type": "string"
                                },
                                "material": {
                                    "title": "Material",
                                    "type": "string"
                                },
                                "description": {
                                    "title": "Description",
                                    "type": "string"
                                },
                                "po_quantity": {
                                    "title": "Po Quantity",
                                    "type": "string"
                                },
                                "supplier_quantity": {
                                    "title": "Supplier Quantity",
                                    "type": "string"
                                },
                                "po_unit_price": {
                                    "title": "Po Unit Price",
                                    "type": "string"
                                },
                                "supplier_unit_price": {
                                    "title": "Supplier Unit Price",
                                    "type": "string"
                                },
                                "currency": {
                                    "title": "Currency",
                                    "type": "string"
                                },
                                "variance_category": {
                                    "description": "One of: price-variance, quantity-variance, uom-mismatch, material-mismatch, currency-mismatch, tax-variance, missing-line, duplicate-line, over-delivery, under-delivery, none.",
                                    "title": "Variance Category",
                                    "type": "string"
                                },
                                "variance_amount": {
                                    "description": "The quantified line variance with currency, e.g. '+\u00a3125.00'.",
                                    "title": "Variance Amount",
                                    "type": "string"
                                },
                                "explanation": {
                                    "description": "Plain-English reason the line disagrees.",
                                    "title": "Explanation",
                                    "type": "string"
                                },
                                "proposed_correction": {
                                    "description": "Recommended PO-item correction for a human buyer to APPROVE before any write \u2014 never a write itself.",
                                    "title": "Proposed Correction",
                                    "type": "string"
                                }
                            },
                            "required": [
                                "po_item",
                                "material",
                                "description",
                                "po_quantity",
                                "supplier_quantity",
                                "po_unit_price",
                                "supplier_unit_price",
                                "currency",
                                "variance_category",
                                "variance_amount",
                                "explanation",
                                "proposed_correction"
                            ],
                            "title": "LineVariance",
                            "type": "object"
                        },
                        "title": "Line Variances",
                        "type": "array"
                    },
                    "prepared_corrections": {
                        "description": "For each line with a variance, the S/4 update that would correct it \u2014 prepared, never posted. The deterministic step posts only after human approval.",
                        "items": {
                            "properties": {
                                "po_item": {
                                    "title": "Po Item",
                                    "type": "string"
                                },
                                "entity": {
                                    "description": "The S/4 OData entity to update (A_PurchaseOrderItem).",
                                    "title": "Entity",
                                    "type": "string"
                                },
                                "field": {
                                    "description": "The S/4 field to change: OrderQuantity for a quantity correction, NetPriceAmount for a price correction.",
                                    "title": "Field",
                                    "type": "string"
                                },
                                "current_value": {
                                    "description": "The current S/4 value (read from the PO).",
                                    "title": "Current Value",
                                    "type": "string"
                                },
                                "new_value": {
                                    "description": "The value that resolves the variance.",
                                    "title": "New Value",
                                    "type": "string"
                                },
                                "summary": {
                                    "description": "One line a buyer reads: what changes, from/to.",
                                    "title": "Summary",
                                    "type": "string"
                                },
                                "ready_to_post": {
                                    "description": "True if well-formed and safe to hand to the deterministic post step.",
                                    "title": "Ready To Post",
                                    "type": "boolean"
                                }
                            },
                            "required": [
                                "po_item",
                                "entity",
                                "field",
                                "current_value",
                                "new_value",
                                "summary",
                                "ready_to_post"
                            ],
                            "title": "PreparedCorrection",
                            "type": "object"
                        },
                        "title": "Prepared Corrections",
                        "type": "array"
                    }
                },
                "required": [
                    "purchase_order",
                    "overall_status",
                    "summary",
                    "confidence",
                    "line_variances",
                    "prepared_corrections"
                ]
            },
            "graph": {
                "nodes": [
                    {
                        "id": "__start__",
                        "name": "__start__",
                        "type": "__start__",
                        "subgraph": null,
                        "metadata": {}
                    },
                    {
                        "id": "reconcile",
                        "name": "reconcile",
                        "type": "node",
                        "subgraph": null,
                        "metadata": {}
                    },
                    {
                        "id": "__end__",
                        "name": "__end__",
                        "type": "__end__",
                        "subgraph": null,
                        "metadata": {}
                    }
                ],
                "edges": [
                    {
                        "source": "__start__",
                        "target": "reconcile",
                        "label": null
                    },
                    {
                        "source": "reconcile",
                        "target": "__end__",
                        "label": null
                    }
                ]
            }
        }
    ]
}